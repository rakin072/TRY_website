@page "/Admin"
@attribute [Microsoft.AspNetCore.Mvc.IgnoreAntiforgeryToken]
@using Microsoft.Data.SqlClient
@using System.Security.Cryptography
@using System.Text
@using System.Data
@using System.Linq
@inject IConfiguration Configuration
@inject IWebHostEnvironment Env
@{
    Layout = null;

    // ── Helpers ─────────────────────────────────────────────────────────────
    string HashPassword(string plain)
    {
        using var sha = SHA256.Create();
        var bytes = sha.ComputeHash(Encoding.UTF8.GetBytes(plain));
        return BitConverter.ToString(bytes).Replace("-", "").ToLower();
    }

    SqlConnection GetConnection()
    {
        var cs = Configuration.GetConnectionString("DefaultConnection");
        var conn = new SqlConnection(cs);
        conn.Open();
        return conn;
    }

    string SaveUpload(IFormFile file, string subfolder)
    {
        var allowed = new[] { ".jpg", ".jpeg", ".png", ".webp", ".gif" };
        var ext = System.IO.Path.GetExtension(file.FileName).ToLower();
        if (!allowed.Contains(ext)) throw new Exception("Invalid file type.");
        var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", subfolder);
        System.IO.Directory.CreateDirectory(dir);
        var fname = Guid.NewGuid().ToString("N") + ext;
        using var fs = new System.IO.FileStream(System.IO.Path.Combine(dir, fname), System.IO.FileMode.Create);
        file.CopyTo(fs);
        return $"/uploads/{subfolder}/{fname}";
    }

    // ── State ────────────────────────────────────────────────────────────────
    var loggedInUser = HttpContext.Session.GetString("AdminUser");
    var isLoggedIn = !string.IsNullOrEmpty(loggedInUser);
    var loginError = "";
    var active = Request.Query["section"].ToString();
    if (string.IsNullOrEmpty(active)) active = "dashboard";
    var msgFlash = Request.Query["msg"].ToString();
    var filterParam = Request.Query["filter"].ToString();

    // ── POST Handling ────────────────────────────────────────────────────────
    if (Request.Method == "POST")
    {
        var action = Request.Form["action"].ToString();

        if (action == "login")
        {
            var uname = Request.Form["username"].ToString();
            var pwd = Request.Form["password"].ToString();
            var hash = HashPassword(pwd);
            try
            {
                using var conn = GetConnection();
                using var cmd = new SqlCommand("SELECT username FROM admin_users WHERE username=@u AND password_hash=@h", conn);
                cmd.Parameters.AddWithValue("@u", uname);
                cmd.Parameters.AddWithValue("@h", hash);
                var result = cmd.ExecuteScalar();
                if (result != null)
                {
                    HttpContext.Session.SetString("AdminUser", uname);
                    Response.Redirect("/Admin");
                    return;
                }
                else
                {
                    loginError = "Invalid username or password.";
                }
            }
            catch { loginError = "Database error. Please try again."; }
        }
        else if (action == "logout")
        {
            HttpContext.Session.Clear();
            Response.Redirect("/Admin");
            return;
        }
        else if (isLoggedIn)
        {
            // ── Activities ──────────────────────────────────────────────────
            if (action == "save_activity")
            {
                var actId = int.Parse(Request.Form["act_id"].ToString() ?? "0");
                var title = Request.Form["act_title"].ToString();
                var desc = Request.Form["act_desc"].ToString();
                var icon = Request.Form["act_icon"].ToString();
                using var conn = GetConnection();
                if (actId == 0)
                {
                    using var cmd = new SqlCommand("INSERT INTO activities (title,description,icon_name,created_at) VALUES (@t,@d,@i,GETDATE())", conn);
                    cmd.Parameters.AddWithValue("@t", title);
                    cmd.Parameters.AddWithValue("@d", (object?)desc ?? DBNull.Value);
                    cmd.Parameters.AddWithValue("@i", (object?)icon ?? DBNull.Value);
                    cmd.ExecuteNonQuery();
                }
                else
                {
                    using var cmd = new SqlCommand("UPDATE activities SET title=@t,description=@d,icon_name=@i WHERE id=@id", conn);
                    cmd.Parameters.AddWithValue("@t", title);
                    cmd.Parameters.AddWithValue("@d", (object?)desc ?? DBNull.Value);
                    cmd.Parameters.AddWithValue("@i", (object?)icon ?? DBNull.Value);
                    cmd.Parameters.AddWithValue("@id", actId);
                    cmd.ExecuteNonQuery();
                }
                Response.Redirect("/Admin?section=activities&msg=saved"); return;
            }
            else if (action == "delete_activity")
            {
                var actId = int.Parse(Request.Form["act_id"].ToString() ?? "0");
                using var conn = GetConnection();
                using var cmd = new SqlCommand("DELETE FROM activities WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", actId);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=activities&msg=deleted"); return;
            }
            // ── News ────────────────────────────────────────────────────────
            else if (action == "save_news")
            {
                var newsId = int.Parse(Request.Form["news_id"].ToString() ?? "0");
                var title = Request.Form["news_title"].ToString();
                var cat = Request.Form["news_cat"].ToString();
                var content = Request.Form["news_content"].ToString();
                var dateStr = Request.Form["news_date"].ToString();
                var isPublished = Request.Form["news_published"].ToString() == "1" ? 1 : 0;
                DateTime? pubDate = string.IsNullOrEmpty(dateStr) ? null : DateTime.Parse(dateStr);
                string? imagePath = null;
                var imgFile = Request.Form.Files["news_image"];
                if (imgFile != null && imgFile.Length > 0) imagePath = SaveUpload(imgFile, "news");
                using var conn = GetConnection();
                if (newsId == 0)
                {
                    using var cmd = new SqlCommand("INSERT INTO news (title,category,content,image_path,published_at,is_published) VALUES (@t,@c,@co,@img,@pd,@ip)", conn);
                    cmd.Parameters.AddWithValue("@t", title);
                    cmd.Parameters.AddWithValue("@c", (object?)cat ?? DBNull.Value);
                    cmd.Parameters.AddWithValue("@co", (object?)content ?? DBNull.Value);
                    cmd.Parameters.Add("@img", SqlDbType.NVarChar, 255).Value = (object?)imagePath ?? DBNull.Value;
                    cmd.Parameters.Add("@pd", SqlDbType.DateTime).Value = (object?)pubDate ?? DBNull.Value;
                    cmd.Parameters.AddWithValue("@ip", isPublished);
                    cmd.ExecuteNonQuery();
                }
                else
                {
                    if (imagePath != null)
                    {
                        using var cmd = new SqlCommand("UPDATE news SET title=@t,category=@c,content=@co,image_path=@img,published_at=@pd,is_published=@ip WHERE id=@id", conn);
                        cmd.Parameters.AddWithValue("@t", title);
                        cmd.Parameters.AddWithValue("@c", (object?)cat ?? DBNull.Value);
                        cmd.Parameters.AddWithValue("@co", (object?)content ?? DBNull.Value);
                        cmd.Parameters.Add("@img", SqlDbType.NVarChar, 255).Value = (object?)imagePath ?? DBNull.Value;
                        cmd.Parameters.Add("@pd", SqlDbType.DateTime).Value = (object?)pubDate ?? DBNull.Value;
                        cmd.Parameters.AddWithValue("@ip", isPublished);
                        cmd.Parameters.AddWithValue("@id", newsId);
                        cmd.ExecuteNonQuery();
                    }
                    else
                    {
                        using var cmd = new SqlCommand("UPDATE news SET title=@t,category=@c,content=@co,published_at=@pd,is_published=@ip WHERE id=@id", conn);
                        cmd.Parameters.AddWithValue("@t", title);
                        cmd.Parameters.AddWithValue("@c", (object?)cat ?? DBNull.Value);
                        cmd.Parameters.AddWithValue("@co", (object?)content ?? DBNull.Value);
                        cmd.Parameters.Add("@pd", SqlDbType.DateTime).Value = (object?)pubDate ?? DBNull.Value;
                        cmd.Parameters.AddWithValue("@ip", isPublished);
                        cmd.Parameters.AddWithValue("@id", newsId);
                        cmd.ExecuteNonQuery();
                    }
                }
                Response.Redirect("/Admin?section=news&msg=saved"); return;
            }
            else if (action == "toggle_news")
            {
                var newsId = int.Parse(Request.Form["news_id"].ToString() ?? "0");
                using var conn = GetConnection();
                using var cmd = new SqlCommand("UPDATE news SET is_published=1-is_published WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", newsId);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=news&msg=toggled"); return;
            }
            else if (action == "delete_news")
            {
                var newsId = int.Parse(Request.Form["news_id"].ToString() ?? "0");
                using var conn = GetConnection();
                using var cmd = new SqlCommand("DELETE FROM news WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", newsId);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=news&msg=deleted"); return;
            }
            // ── Impact Stories ──────────────────────────────────────────────
            else if (action == "save_story")
            {
                var storyId = int.Parse(Request.Form["story_id"].ToString() ?? "0");
                var quote = Request.Form["story_quote"].ToString();
                var author = Request.Form["story_author"].ToString();
                var role = Request.Form["story_role"].ToString();
                using var conn = GetConnection();
                if (storyId == 0)
                {
                    using var cmd = new SqlCommand("INSERT INTO impact_stories (quote_text,author_name,author_role,created_at) VALUES (@q,@a,@r,GETDATE())", conn);
                    cmd.Parameters.AddWithValue("@q", quote);
                    cmd.Parameters.AddWithValue("@a", author);
                    cmd.Parameters.AddWithValue("@r", (object?)role ?? DBNull.Value);
                    cmd.ExecuteNonQuery();
                }
                else
                {
                    using var cmd = new SqlCommand("UPDATE impact_stories SET quote_text=@q,author_name=@a,author_role=@r WHERE id=@id", conn);
                    cmd.Parameters.AddWithValue("@q", quote);
                    cmd.Parameters.AddWithValue("@a", author);
                    cmd.Parameters.AddWithValue("@r", (object?)role ?? DBNull.Value);
                    cmd.Parameters.AddWithValue("@id", storyId);
                    cmd.ExecuteNonQuery();
                }
                Response.Redirect("/Admin?section=stories&msg=saved"); return;
            }
            else if (action == "delete_story")
            {
                var storyId = int.Parse(Request.Form["story_id"].ToString() ?? "0");
                using var conn = GetConnection();
                using var cmd = new SqlCommand("DELETE FROM impact_stories WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", storyId);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=stories&msg=deleted"); return;
            }
            // ── Gallery ─────────────────────────────────────────────────────
            else if (action == "upload_gallery")
            {
                var galFile = Request.Form.Files["gal_image"];
                var caption = Request.Form["gal_caption"].ToString();
                if (galFile != null && galFile.Length > 0)
                {
                    var path = SaveUpload(galFile, "gallery");
                    using var conn = GetConnection();
                    using var cmd = new SqlCommand("INSERT INTO gallery (image_path,caption,created_at) VALUES (@p,@c,GETDATE())", conn);
                    cmd.Parameters.AddWithValue("@p", path);
                    cmd.Parameters.AddWithValue("@c", (object?)caption ?? DBNull.Value);
                    cmd.ExecuteNonQuery();
                }
                Response.Redirect("/Admin?section=gallery&msg=uploaded"); return;
            }
            else if (action == "delete_gallery")
            {
                var galId = int.Parse(Request.Form["gal_id"].ToString() ?? "0");
                using var conn = GetConnection();
                string? filePath = null;
                using (var cmd = new SqlCommand("SELECT image_path FROM gallery WHERE id=@id", conn))
                {
                    cmd.Parameters.AddWithValue("@id", galId);
                    filePath = cmd.ExecuteScalar()?.ToString();
                }
                using (var cmd = new SqlCommand("DELETE FROM gallery WHERE id=@id", conn))
                {
                    cmd.Parameters.AddWithValue("@id", galId);
                    cmd.ExecuteNonQuery();
                }
                if (!string.IsNullOrEmpty(filePath))
                {
                    var physPath = System.IO.Path.Combine(Env.WebRootPath, filePath.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar));
                    if (System.IO.File.Exists(physPath)) System.IO.File.Delete(physPath);
                }
                Response.Redirect("/Admin?section=gallery&msg=deleted"); return;
            }
            // ── Messages ────────────────────────────────────────────────────
            else if (action == "mark_all_read")
            {
                using var conn = GetConnection();
                using var cmd = new SqlCommand("UPDATE messages SET is_read=1", conn);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=messages&msg=all_read"); return;
            }
            else if (action == "toggle_msg")
            {
                var msgId = int.Parse(Request.Form["msg_id"].ToString() ?? "0");
                using var conn = GetConnection();
                using var cmd = new SqlCommand("UPDATE messages SET is_read=1-is_read WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", msgId);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=messages&msg=toggled"); return;
            }
            else if (action == "delete_msg")
            {
                var msgId = int.Parse(Request.Form["msg_id"].ToString() ?? "0");
                using var conn = GetConnection();
                using var cmd = new SqlCommand("DELETE FROM messages WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", msgId);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=messages&msg=deleted"); return;
            }
            // ── Volunteers ──────────────────────────────────────────────────
            else if (action == "set_volunteer_status")
            {
                var volId = int.Parse(Request.Form["vol_id"].ToString() ?? "0");
                var volStatus = Request.Form["vol_status"].ToString();
                if (volStatus != "Approved" && volStatus != "Rejected" && volStatus != "Pending") volStatus = "Pending";
                using var conn = GetConnection();
                using var cmd = new SqlCommand("UPDATE volunteers SET status=@s WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@s", volStatus);
                cmd.Parameters.AddWithValue("@id", volId);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=volunteers&msg=updated"); return;
            }
            else if (action == "delete_volunteer")
            {
                var volId = int.Parse(Request.Form["vol_id"].ToString() ?? "0");
                using var conn = GetConnection();
                using var cmd = new SqlCommand("DELETE FROM volunteers WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", volId);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=volunteers&msg=deleted"); return;
            }
            // ── Site Stats ──────────────────────────────────────────────────
            else if (action == "save_stats")
            {
                var vCount = int.Parse(Request.Form["stat_volunteers"].ToString() ?? "0");
                var pCount = int.Parse(Request.Form["stat_projects"].ToString() ?? "0");
                var hCount = int.Parse(Request.Form["stat_helped"].ToString() ?? "0");
                var yCount = int.Parse(Request.Form["stat_years"].ToString() ?? "0");
                using var conn = GetConnection();
                using var cmd = new SqlCommand("UPDATE site_stats SET volunteers_count=@v,projects_count=@p,people_helped=@h,years_active=@y WHERE id=1", conn);
                cmd.Parameters.AddWithValue("@v", vCount);
                cmd.Parameters.AddWithValue("@p", pCount);
                cmd.Parameters.AddWithValue("@h", hCount);
                cmd.Parameters.AddWithValue("@y", yCount);
                cmd.ExecuteNonQuery();
                Response.Redirect("/Admin?section=stats&msg=saved"); return;
            }
        }
    }

    // ── Data Loading (GET or after failed POST) ──────────────────────────────
    // Only load data if logged in (session guard)
    int cntActivities = 0, cntNews = 0, cntPublished = 0, cntGallery = 0, cntUnreadMsgs = 0, cntPendingVols = 0;
    var activities = new List<dynamic>();
    var newsList = new List<dynamic>();
    var stories = new List<dynamic>();
    var gallery = new List<dynamic>();
    var messages = new List<dynamic>();
    var volunteers = new List<dynamic>();
    int statVolunteers = 0, statProjects = 0, statHelped = 0, statYears = 0;
    var recentMessages = new List<dynamic>();
    var recentVolunteers = new List<dynamic>();

    // Pre-fill for edit
    dynamic? editActivity = null;
    dynamic? editNews = null;
    dynamic? editStory = null;

    if (isLoggedIn)
    {
        try
        {
            using var conn = GetConnection();

            // ── Dashboard counts ────────────────────────────────────────────
            using (var cmd = new SqlCommand("SELECT COUNT(*) FROM activities", conn))
                cntActivities = (int)cmd.ExecuteScalar();
            using (var cmd = new SqlCommand("SELECT COUNT(*) FROM news", conn))
                cntNews = (int)cmd.ExecuteScalar();
            using (var cmd = new SqlCommand("SELECT COUNT(*) FROM news WHERE is_published=1", conn))
                cntPublished = (int)cmd.ExecuteScalar();
            using (var cmd = new SqlCommand("SELECT COUNT(*) FROM gallery", conn))
                cntGallery = (int)cmd.ExecuteScalar();
            using (var cmd = new SqlCommand("SELECT COUNT(*) FROM messages WHERE is_read=0", conn))
                cntUnreadMsgs = (int)cmd.ExecuteScalar();
            using (var cmd = new SqlCommand("SELECT COUNT(*) FROM volunteers WHERE status='Pending'", conn))
                cntPendingVols = (int)cmd.ExecuteScalar();

            // ── Recent messages (dashboard) ─────────────────────────────────
            using (var cmd = new SqlCommand("SELECT TOP 5 name,subject,received_at,is_read FROM messages ORDER BY received_at DESC", conn))
            using (var rdr = cmd.ExecuteReader())
                while (rdr.Read())
                    recentMessages.Add(new { Name = rdr.GetString(0), Subject = rdr.IsDBNull(1) ? "" : rdr.GetString(1), ReceivedAt = rdr.GetDateTime(2).ToString("dd MMM yy HH:mm"), IsRead = rdr.GetBoolean(3) });

            // ── Recent volunteers (dashboard) ────────────────────────────────
            using (var cmd = new SqlCommand("SELECT TOP 5 name,email,status,submitted_at FROM volunteers ORDER BY submitted_at DESC", conn))
            using (var rdr = cmd.ExecuteReader())
                while (rdr.Read())
                    recentVolunteers.Add(new { Name = rdr.GetString(0), Email = rdr.GetString(1), Status = rdr.GetString(2), SubmittedAt = rdr.GetDateTime(3).ToString("dd MMM yy") });

            // ── Activities list ─────────────────────────────────────────────
            using (var cmd = new SqlCommand("SELECT id,title,description,icon_name,created_at FROM activities ORDER BY created_at DESC", conn))
            using (var rdr = cmd.ExecuteReader())
                while (rdr.Read())
                    activities.Add(new { Id = rdr.GetInt32(0), Title = rdr.GetString(1), Description = rdr.IsDBNull(2) ? "" : rdr.GetString(2), Icon = rdr.IsDBNull(3) ? "" : rdr.GetString(3), CreatedAt = rdr.GetDateTime(4).ToString("dd MMM yyyy") });

            // ── Edit activity pre-fill ──────────────────────────────────────
            var editActId = Request.Query["edit_id"].ToString();
            if (active == "activities" && !string.IsNullOrEmpty(editActId))
            {
                using var cmd = new SqlCommand("SELECT id,title,description,icon_name FROM activities WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", int.Parse(editActId));
                using var rdr = cmd.ExecuteReader();
                if (rdr.Read())
                    editActivity = new { Id = rdr.GetInt32(0), Title = rdr.GetString(1), Description = rdr.IsDBNull(2) ? "" : rdr.GetString(2), Icon = rdr.IsDBNull(3) ? "" : rdr.GetString(3) };
            }

            // ── News list ───────────────────────────────────────────────────
            using (var cmd = new SqlCommand("SELECT id,title,category,published_at,is_published,image_path FROM news ORDER BY COALESCE(published_at, GETDATE()) DESC", conn))
            using (var rdr = cmd.ExecuteReader())
                while (rdr.Read())
                    newsList.Add(new { Id = rdr.GetInt32(0), Title = rdr.GetString(1), Category = rdr.IsDBNull(2) ? "" : rdr.GetString(2), PublishedAt = rdr.IsDBNull(3) ? "" : rdr.GetDateTime(3).ToString("dd MMM yyyy"), IsPublished = rdr.GetBoolean(4), Image = rdr.IsDBNull(5) ? "" : rdr.GetString(5) });

            // ── Edit news pre-fill ──────────────────────────────────────────
            var editNewsId = Request.Query["edit_id"].ToString();
            if (active == "news" && !string.IsNullOrEmpty(editNewsId))
            {
                using var cmd = new SqlCommand("SELECT id,title,category,content,published_at,is_published,image_path FROM news WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", int.Parse(editNewsId));
                using var rdr = cmd.ExecuteReader();
                if (rdr.Read())
                    editNews = new { Id = rdr.GetInt32(0), Title = rdr.GetString(1), Category = rdr.IsDBNull(2) ? "" : rdr.GetString(2), Content = rdr.IsDBNull(3) ? "" : rdr.GetString(3), PublishedAt = rdr.IsDBNull(4) ? "" : rdr.GetDateTime(4).ToString("yyyy-MM-dd"), IsPublished = rdr.GetBoolean(5), Image = rdr.IsDBNull(6) ? "" : rdr.GetString(6) };
            }

            // ── Stories list ────────────────────────────────────────────────
            using (var cmd = new SqlCommand("SELECT id,quote_text,author_name,author_role,created_at FROM impact_stories ORDER BY created_at DESC", conn))
            using (var rdr = cmd.ExecuteReader())
                while (rdr.Read())
                    stories.Add(new { Id = rdr.GetInt32(0), Quote = rdr.GetString(1), Author = rdr.GetString(2), Role = rdr.IsDBNull(3) ? "" : rdr.GetString(3), CreatedAt = rdr.GetDateTime(4).ToString("dd MMM yyyy") });

            // ── Edit story pre-fill ─────────────────────────────────────────
            var editStoryId = Request.Query["edit_id"].ToString();
            if (active == "stories" && !string.IsNullOrEmpty(editStoryId))
            {
                using var cmd = new SqlCommand("SELECT id,quote_text,author_name,author_role FROM impact_stories WHERE id=@id", conn);
                cmd.Parameters.AddWithValue("@id", int.Parse(editStoryId));
                using var rdr = cmd.ExecuteReader();
                if (rdr.Read())
                    editStory = new { Id = rdr.GetInt32(0), Quote = rdr.GetString(1), Author = rdr.GetString(2), Role = rdr.IsDBNull(3) ? "" : rdr.GetString(3) };
            }

            // ── Gallery list ────────────────────────────────────────────────
            using (var cmd = new SqlCommand("SELECT id,image_path,caption,created_at FROM gallery ORDER BY created_at DESC", conn))
            using (var rdr = cmd.ExecuteReader())
                while (rdr.Read())
                    gallery.Add(new { Id = rdr.GetInt32(0), Path = rdr.GetString(1), Caption = rdr.IsDBNull(2) ? "" : rdr.GetString(2), CreatedAt = rdr.GetDateTime(3).ToString("dd MMM yyyy") });

            // ── Messages list ───────────────────────────────────────────────
            var msgWhere = filterParam switch { "unread" => " WHERE is_read=0", "read" => " WHERE is_read=1", _ => "" };
            using (var cmd = new SqlCommand($"SELECT id,name,email,subject,message,received_at,is_read FROM messages{msgWhere} ORDER BY received_at DESC", conn))
            using (var rdr = cmd.ExecuteReader())
                while (rdr.Read())
                    messages.Add(new { Id = rdr.GetInt32(0), Name = rdr.GetString(1), Email = rdr.GetString(2), Subject = rdr.IsDBNull(3) ? "" : rdr.GetString(3), Message = rdr.IsDBNull(4) ? "" : rdr.GetString(4), ReceivedAt = rdr.GetDateTime(5).ToString("dd MMM yy HH:mm"), IsRead = rdr.GetBoolean(6) });

            // ── Volunteers list ─────────────────────────────────────────────
            var volWhere = (filterParam == "Pending" || filterParam == "Approved" || filterParam == "Rejected") ? $" WHERE status='{filterParam}'" : "";
            using (var cmd = new SqlCommand($"SELECT id,name,email,phone,submitted_at,status FROM volunteers{volWhere} ORDER BY submitted_at DESC", conn))
            using (var rdr = cmd.ExecuteReader())
                while (rdr.Read())
                    volunteers.Add(new { Id = rdr.GetInt32(0), Name = rdr.GetString(1), Email = rdr.GetString(2), Phone = rdr.IsDBNull(3) ? "" : rdr.GetString(3), SubmittedAt = rdr.GetDateTime(4).ToString("dd MMM yyyy"), Status = rdr.GetString(5) });

            // ── Site stats ──────────────────────────────────────────────────
            using (var cmd = new SqlCommand("SELECT volunteers_count,projects_count,people_helped,years_active FROM site_stats WHERE id=1", conn))
            using (var rdr = cmd.ExecuteReader())
                if (rdr.Read()) { statVolunteers = rdr.GetInt32(0); statProjects = rdr.GetInt32(1); statHelped = rdr.GetInt32(2); statYears = rdr.GetInt32(3); }
        }
        catch
        {
            // Silently fail individual queries — the page will still render with empty lists
        }
    }

    // ── Flash message text ───────────────────────────────────────────────────
    var flashText = msgFlash switch
    {
        "saved" => "✅ Record saved successfully.",
        "deleted" => "🗑️ Record deleted.",
        "toggled" => "🔄 Status updated.",
        "uploaded" => "📤 Image uploaded successfully.",
        "all_read" => "✅ All messages marked as read.",
        "updated" => "✅ Status updated.",
        _ => ""
    };

    // ── Sidebar active class helper ──────────────────────────────────────────
    string NavClass(string s) => active == s ? "nav-item active" : "nav-item";

    // ── Display helper ───────────────────────────────────────────────────────
    string Show(string s) => active == s ? "block" : "none";

    // ── Section title ────────────────────────────────────────────────────────
    var sectionTitle = active switch
    {
        "dashboard"  => "Dashboard",
        "activities" => "Activities",
        "news"       => "News Management",
        "stories"    => "Impact Stories",
        "gallery"    => "Gallery",
        "messages"   => "Messages",
        "volunteers" => "Volunteers",
        "stats"      => "Site Statistics",
        _            => "Dashboard"
    };
}
