<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel — TRY KUET</title>
    <meta name="description" content="TRY KUET Social Service Club — Admin Management Panel">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/Admin/admin.css">
</head>
<body>

@if (!isLoggedIn)
{
    <!-- ═══════════════════ LOGIN SCREEN ═══════════════════ -->
    <div class="login-wrap">
        <div class="login-card">
            <div class="login-logo">
                <div class="login-logo-icon"><i class="fa-solid fa-shield-halved"></i></div>
                <h2>TRY Admin</h2>
                <p>KUET Social Service Club</p>
            </div>
            @if (!string.IsNullOrEmpty(loginError))
            {
                <div class="flash flash-error" style="margin:0 0 16px;"><i class="fa-solid fa-triangle-exclamation"></i> @loginError</div>
            }
            <form method="post" action="/Admin">
                <input name="action" value="login" type="hidden">
                <div class="form-group">
                    <label for="login-username"><i class="fa-solid fa-user"></i> Username</label>
                    <input type="text" id="login-username" name="username" required autocomplete="username" placeholder="Enter username">
                </div>
                <div class="form-group">
                    <label for="login-password"><i class="fa-solid fa-lock"></i> Password</label>
                    <input type="password" id="login-password" name="password" required autocomplete="current-password" placeholder="Enter password">
                </div>
                <button type="submit" class="btn btn-primary btn-block" id="login-btn">
                    <i class="fa-solid fa-right-to-bracket"></i> Login
                </button>
            </form>
        </div>
    </div>
}
else
{
    <!-- ═══════════════════ ADMIN PANEL ═══════════════════ -->
    <div class="admin-wrap">

        <!-- ── SIDEBAR ──────────────────────────────────────────────── -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon"><i class="fa-solid fa-hands-helping"></i></div>
                <div><span class="logo-try">TRY</span> KUET</div>
                <small>Admin Panel</small>
            </div>

            <nav class="sidebar-nav">
                <a href="/Admin?section=dashboard" class="@NavClass("dashboard")">
                    <i class="fa-solid fa-gauge-high nav-icon"></i> Dashboard
                </a>
                <a href="/Admin?section=activities" class="@NavClass("activities")">
                    <i class="fa-solid fa-list-check nav-icon"></i> Activities
                </a>
                <a href="/Admin?section=news" class="@NavClass("news")">
                    <i class="fa-solid fa-newspaper nav-icon"></i> News
                </a>
                <a href="/Admin?section=stories" class="@NavClass("stories")">
                    <i class="fa-solid fa-quote-left nav-icon"></i> Impact Stories
                </a>
                <a href="/Admin?section=gallery" class="@NavClass("gallery")">
                    <i class="fa-solid fa-images nav-icon"></i> Gallery
                </a>
                <a href="/Admin?section=messages" class="@NavClass("messages")">
                    <i class="fa-solid fa-envelope nav-icon"></i> Messages
                    @if (cntUnreadMsgs > 0)
                    {
                        <span class="nav-badge">@cntUnreadMsgs</span>
                    }
                </a>
                <a href="/Admin?section=volunteers" class="@NavClass("volunteers")">
                    <i class="fa-solid fa-people-group nav-icon"></i> Volunteers
                    @if (cntPendingVols > 0)
                    {
                        <span class="nav-badge">@cntPendingVols</span>
                    }
                </a>
                <a href="/Admin?section=stats" class="@NavClass("stats")">
                    <i class="fa-solid fa-chart-bar nav-icon"></i> Site Stats
                </a>
            </nav>

            <div class="sidebar-footer">
                <form method="post" action="/Admin">
                    <input name="action" value="logout" type="hidden">
                    <button type="submit" class="btn-logout" id="logout-btn">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </button>
                </form>
            </div>
        </aside>

        <!-- ── MAIN CONTENT ──────────────────────────────────────────── -->
        <main class="admin-main">

            <!-- TOP BAR -->
            <header class="topbar">
                <div class="topbar-left">
                    <button class="sidebar-toggle" id="sidebar-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <span class="page-title">@sectionTitle</span>
                </div>
                <div class="admin-info">
                    <div class="admin-avatar"><i class="fa-solid fa-user"></i></div>
                    <span class="admin-name">@loggedInUser</span>
                </div>
            </header>

            <!-- FLASH MESSAGE -->
            @if (!string.IsNullOrEmpty(flashText))
            {
                <div class="flash flash-success" id="flash-msg">@flashText</div>
            }

            <!-- ══════════════ SECTION: DASHBOARD ══════════════ -->
            <section id="sec-dashboard" style="display:@Show("dashboard")">
                <div class="stats-row">
                    <div class="stat-card" style="border-left-color:#e94560">
                        <div class="stat-icon" style="background:#fde8ec"><i class="fa-solid fa-list-check" style="color:#e94560"></i></div>
                        <div class="num">@cntActivities</div>
                        <div class="lbl">Activities</div>
                    </div>
                    <div class="stat-card" style="border-left-color:#0984e3">
                        <div class="stat-icon" style="background:#dbeeff"><i class="fa-solid fa-newspaper" style="color:#0984e3"></i></div>
                        <div class="num">@cntNews</div>
                        <div class="lbl">News Posts</div>
                    </div>
                    <div class="stat-card" style="border-left-color:#00b894">
                        <div class="stat-icon" style="background:#d4f7ee"><i class="fa-solid fa-circle-check" style="color:#00b894"></i></div>
                        <div class="num">@cntPublished</div>
                        <div class="lbl">Published</div>
                    </div>
                    <div class="stat-card" style="border-left-color:#6c5ce7">
                        <div class="stat-icon" style="background:#ede9fd"><i class="fa-solid fa-images" style="color:#6c5ce7"></i></div>
                        <div class="num">@cntGallery</div>
                        <div class="lbl">Gallery Items</div>
                    </div>
                    <div class="stat-card" style="border-left-color:#fdcb6e">
                        <div class="stat-icon" style="background:#fff8e7"><i class="fa-solid fa-envelope" style="color:#fdcb6e"></i></div>
                        <div class="num">@cntUnreadMsgs</div>
                        <div class="lbl">Unread Messages</div>
                    </div>
                    <div class="stat-card" style="border-left-color:#fd79a8">
                        <div class="stat-icon" style="background:#fde8f3"><i class="fa-solid fa-hourglass-half" style="color:#fd79a8"></i></div>
                        <div class="num">@cntPendingVols</div>
                        <div class="lbl">Pending Volunteers</div>
                    </div>
                </div>

                <div class="section-body">
                    <div class="dual-tables">
                        <div class="card-box">
                            <h3 class="section-title"><i class="fa-solid fa-envelope"></i> Latest Messages</h3>
                            <div class="table-wrap">
                                <table class="admin-table">
                                    <thead><tr><th>Name</th><th>Subject</th><th>Received</th><th>Status</th></tr></thead>
                                    <tbody>
                                    @foreach (dynamic m in recentMessages)
                                    {
                                        <tr>
                                            <td>@m.Name</td>
                                            <td>@m.Subject</td>
                                            <td>@m.ReceivedAt</td>
                                            <td>
                                                @if ((bool)m.IsRead)
                                                { <span class="badge badge-secondary">Read</span> }
                                                else
                                                { <span class="badge badge-danger">Unread</span> }
                                            </td>
                                        </tr>
                                    }
                                    @if (!recentMessages.Any())
                                    {
                                        <tr><td colspan="4" class="empty-row">No messages yet.</td></tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="card-box">
                            <h3 class="section-title"><i class="fa-solid fa-people-group"></i> Latest Volunteers</h3>
                            <div class="table-wrap">
                                <table class="admin-table">
                                    <thead><tr><th>Name</th><th>Email</th><th>Status</th><th>Submitted</th></tr></thead>
                                    <tbody>
                                    @foreach (dynamic v in recentVolunteers)
                                    {
                                        <tr>
                                            <td>@v.Name</td>
                                            <td>@v.Email</td>
                                            <td>
                                                @{ var vc = v.Status == "Approved" ? "badge-success" : v.Status == "Rejected" ? "badge-danger" : "badge-warning"; }
                                                <span class="badge @vc">@v.Status</span>
                                            </td>
                                            <td>@v.SubmittedAt</td>
                                        </tr>
                                    }
                                    @if (!recentVolunteers.Any())
                                    {
                                        <tr><td colspan="4" class="empty-row">No volunteers yet.</td></tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ══════════════ SECTION: ACTIVITIES ══════════════ -->
            <section id="sec-activities" style="display:@Show("activities")">
                <div class="section-body">
                    <div class="card-box">
                        <h3 class="section-title">@(editActivity != null ? "✏️ Edit Activity" : "➕ Add Activity")</h3>
                        <form method="post" action="/Admin?section=activities">
                            <input name="action" value="save_activity" type="hidden">
                            <input name="act_id" value="@(editActivity != null ? editActivity.Id : 0)" type="hidden" id="act_id_hidden">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="act_title">Title *</label>
                                    <input type="text" id="act_title" name="act_title" required value="@(editActivity != null ? editActivity.Title : "")">
                                </div>
                                <div class="form-group">
                                    <label for="act_icon">Icon Class</label>
                                    <input type="text" id="act_icon" name="act_icon" placeholder="fa-solid fa-heart" value="@(editActivity != null ? editActivity.Icon : "")">
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="act_desc">Description</label>
                                <textarea id="act_desc" name="act_desc" rows="3">@(editActivity != null ? editActivity.Description : "")</textarea>
                            </div>
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary" id="save-activity-btn">
                                    <i class="fa-solid fa-floppy-disk"></i> @(editActivity != null ? "Update Activity" : "Save Activity")
                                </button>
                                @if (editActivity != null)
                                {
                                    <a href="/Admin?section=activities" class="btn btn-secondary" id="cancel-edit-activity">Cancel</a>
                                }
                            </div>
                        </form>
                    </div>

                    <div class="card-box">
                        <h3 class="section-title"><i class="fa-solid fa-list"></i> All Activities (@activities.Count)</h3>
                        <div class="table-wrap">
                            <table class="admin-table">
                                <thead><tr><th>#</th><th>Title</th><th>Icon</th><th>Description</th><th>Created</th><th>Actions</th></tr></thead>
                                <tbody>
                                @{ int aIdx = 1; }
                                @foreach (dynamic a in activities)
                                {
                                    <tr>
                                        <td>@(aIdx++)</td>
                                        <td><strong>@a.Title</strong></td>
                                        <td><i class="@a.Icon"></i> <small>@a.Icon</small></td>
                                        <td>@(a.Description.Length > 80 ? a.Description.Substring(0, 80) + "…" : a.Description)</td>
                                        <td>@a.CreatedAt</td>
                                        <td class="action-cell">
                                            <a href="/Admin?section=activities&edit_id=@a.Id" class="btn btn-warning btn-sm"><i class="fa-solid fa-pen"></i> Edit</a>
                                            <form method="post" action="/Admin?section=activities" style="display:inline">
                                                <input name="action" value="delete_activity" type="hidden">
                                                <input name="act_id" value="@a.Id" type="hidden">
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this activity?')"><i class="fa-solid fa-trash"></i> Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                                @if (!activities.Any())
                                {
                                    <tr><td colspan="6" class="empty-row">No activities found.</td></tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ══════════════ SECTION: NEWS ══════════════ -->
            <section id="sec-news" style="display:@Show("news")">
                <div class="section-body">
                    <div class="card-box">
                        <h3 class="section-title">@(editNews != null ? "✏️ Edit News" : "➕ Add News")</h3>
                        <form method="post" action="/Admin?section=news" enctype="multipart/form-data">
                            <input name="action" value="save_news" type="hidden">
                            <input name="news_id" value="@(editNews != null ? editNews.Id : 0)" type="hidden">
                            <div class="form-row">
                                <div class="form-group" style="flex:2">
                                    <label for="news_title">Title *</label>
                                    <input type="text" id="news_title" name="news_title" required value="@(editNews != null ? editNews.Title : "")">
                                </div>
                                <div class="form-group">
                                    <label for="news_cat">Category</label>
                                    <input type="text" id="news_cat" name="news_cat" placeholder="Event / Announcement / Update" value="@(editNews != null ? editNews.Category : "")">
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="news_content">Content</label>
                                <textarea id="news_content" name="news_content" rows="5">@(editNews != null ? editNews.Content : "")</textarea>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="news_date">Published At</label>
                                    <input type="date" id="news_date" name="news_date" value="@(editNews != null ? editNews.PublishedAt : "")">
                                </div>
                                <div class="form-group">
                                    <label for="news_image">Image (leave blank to keep existing)</label>
                                    <input type="file" id="news_image" name="news_image" accept=".jpg,.jpeg,.png,.webp,.gif" class="file-input">
                                </div>
                                <div class="form-group" style="display:flex;align-items:flex-end;padding-bottom:4px">
                                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                        <input type="checkbox" id="news_published" name="news_published" value="1" @(editNews?.IsPublished == true ? "checked" : "")>
                                        <span>Published</span>
                                    </label>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty((string?)editNews?.Image))
                            {
                                <div class="current-image-wrap">
                                    <small>Current image:</small>
                                    <img src="@(editNews?.Image)" alt="Current" class="current-thumb">
                                </div>
                            }
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary" id="save-news-btn">
                                    <i class="fa-solid fa-floppy-disk"></i> @(editNews != null ? "Update News" : "Save News")
                                </button>
                                @if (editNews != null)
                                {
                                    <a href="/Admin?section=news" class="btn btn-secondary" id="cancel-edit-news">Cancel</a>
                                }
                            </div>
                        </form>
                    </div>

                    <div class="card-box">
                        <h3 class="section-title"><i class="fa-solid fa-newspaper"></i> All News (@newsList.Count)</h3>
                        <div class="table-wrap">
                            <table class="admin-table">
                                <thead><tr><th>#</th><th>Title</th><th>Category</th><th>Published At</th><th>Status</th><th>Image</th><th>Actions</th></tr></thead>
                                <tbody>
                                @{ int nIdx = 1; }
                                @foreach (dynamic n in newsList)
                                {
                                    <tr>
                                        <td>@(nIdx++)</td>
                                        <td><strong>@n.Title</strong></td>
                                        <td>@n.Category</td>
                                        <td>@n.PublishedAt</td>
                                        <td>
                                            @if ((bool)n.IsPublished)
                                            { <span class="badge badge-success">🟢 Published</span> }
                                            else
                                            { <span class="badge badge-secondary">⚫ Draft</span> }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(n.Image))
                                            {
                                                <img src="@n.Image" alt="thumb" class="table-thumb">
                                            }
                                        </td>
                                        <td class="action-cell">
                                            <a href="/Admin?section=news&edit_id=@n.Id" class="btn btn-warning btn-sm"><i class="fa-solid fa-pen"></i> Edit</a>
                                            <form method="post" action="/Admin?section=news" style="display:inline">
                                                <input name="action" value="toggle_news" type="hidden">
                                                <input name="news_id" value="@n.Id" type="hidden">
                                                <button type="submit" class="btn btn-sm" style="background:#0984e3;color:#fff"><i class="fa-solid fa-toggle-on"></i> Toggle</button>
                                            </form>
                                            <form method="post" action="/Admin?section=news" style="display:inline">
                                                <input name="action" value="delete_news" type="hidden">
                                                <input name="news_id" value="@n.Id" type="hidden">
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this news post?')"><i class="fa-solid fa-trash"></i> Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                                @if (!newsList.Any())
                                {
                                    <tr><td colspan="7" class="empty-row">No news posts found.</td></tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ══════════════ SECTION: IMPACT STORIES ══════════════ -->
            <section id="sec-stories" style="display:@Show("stories")">
                <div class="section-body">
                    <div class="card-box">
                        <h3 class="section-title">@(editStory != null ? "✏️ Edit Story" : "➕ Add Impact Story")</h3>
                        <form method="post" action="/Admin?section=stories">
                            <input name="action" value="save_story" type="hidden">
                            <input name="story_id" value="@(editStory != null ? editStory.Id : 0)" type="hidden">
                            <div class="form-group">
                                <label for="story_quote">Quote Text *</label>
                                <textarea id="story_quote" name="story_quote" rows="4" required>@(editStory != null ? editStory.Quote : "")</textarea>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="story_author">Author Name *</label>
                                    <input type="text" id="story_author" name="story_author" required value="@(editStory != null ? editStory.Author : "")">
                                </div>
                                <div class="form-group">
                                    <label for="story_role">Author Role</label>
                                    <input type="text" id="story_role" name="story_role" placeholder="Volunteer / Beneficiary" value="@(editStory != null ? editStory.Role : "")">
                                </div>
                            </div>
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary" id="save-story-btn">
                                    <i class="fa-solid fa-floppy-disk"></i> @(editStory != null ? "Update Story" : "Save Story")
                                </button>
                                @if (editStory != null)
                                {
                                    <a href="/Admin?section=stories" class="btn btn-secondary" id="cancel-edit-story">Cancel</a>
                                }
                            </div>
                        </form>
                    </div>

                    <div class="card-box">
                        <h3 class="section-title"><i class="fa-solid fa-quote-left"></i> All Stories (@stories.Count)</h3>
                        <div class="table-wrap">
                            <table class="admin-table">
                                <thead><tr><th>#</th><th>Quote</th><th>Author</th><th>Role</th><th>Created</th><th>Actions</th></tr></thead>
                                <tbody>
                                @{ int sIdx = 1; }
                                @foreach (dynamic s in stories)
                                {
                                    <tr>
                                        <td>@(sIdx++)</td>
                                        <td>@(s.Quote.Length > 100 ? s.Quote.Substring(0, 100) + "…" : s.Quote)</td>
                                        <td><strong>@s.Author</strong></td>
                                        <td>@s.Role</td>
                                        <td>@s.CreatedAt</td>
                                        <td class="action-cell">
                                            <a href="/Admin?section=stories&edit_id=@s.Id" class="btn btn-warning btn-sm"><i class="fa-solid fa-pen"></i> Edit</a>
                                            <form method="post" action="/Admin?section=stories" style="display:inline">
                                                <input name="action" value="delete_story" type="hidden">
                                                <input name="story_id" value="@s.Id" type="hidden">
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this story?')"><i class="fa-solid fa-trash"></i> Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                                @if (!stories.Any())
                                {
                                    <tr><td colspan="6" class="empty-row">No stories found.</td></tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ══════════════ SECTION: GALLERY ══════════════ -->
            <section id="sec-gallery" style="display:@Show("gallery")">
                <div class="section-body">
                    <div class="card-box">
                        <h3 class="section-title">📤 Upload Image</h3>
                        <form method="post" action="/Admin?section=gallery" enctype="multipart/form-data">
                            <input name="action" value="upload_gallery" type="hidden">
                            <div class="form-row">
                                <div class="form-group" style="flex:2">
                                    <label for="gal_image">Image File *</label>
                                    <input type="file" id="gal_image" name="gal_image" accept=".jpg,.jpeg,.png,.webp,.gif" required class="file-input">
                                </div>
                                <div class="form-group">
                                    <label for="gal_caption">Caption</label>
                                    <input type="text" id="gal_caption" name="gal_caption" placeholder="Optional caption">
                                </div>
                            </div>
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary" id="upload-gallery-btn">
                                    <i class="fa-solid fa-cloud-arrow-up"></i> Upload Image
                                </button>
                            </div>
                        </form>
                    </div>

                    <div class="card-box">
                        <h3 class="section-title"><i class="fa-solid fa-images"></i> Gallery (@gallery.Count items)</h3>
                        @if (gallery.Any())
                        {
                            <div class="gallery-grid">
                            @foreach (dynamic g in gallery)
                            {
                                <div class="gallery-item">
                                    <img src="@g.Path" alt="@g.Caption" loading="lazy">
                                    <p>@g.Caption</p>
                                    <small class="muted">@g.CreatedAt</small>
                                    <form method="post" action="/Admin?section=gallery" style="margin-top:6px">
                                        <input name="action" value="delete_gallery" type="hidden">
                                        <input name="gal_id" value="@g.Id" type="hidden">
                                        <button type="submit" class="btn btn-danger btn-sm btn-block" onclick="return confirm('Delete this image permanently?')">
                                            <i class="fa-solid fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            }
                            </div>
                        }
                        else
                        {
                            <p class="empty-row">No gallery images yet. Upload your first image above.</p>
                        }
                    </div>
                </div>
            </section>

            <!-- ══════════════ SECTION: MESSAGES ══════════════ -->
            <section id="sec-messages" style="display:@Show("messages")">
                <div class="section-body">
                    <div class="card-box">
                        <div class="section-toolbar">
                            <div class="filter-tabs">
                                <a href="/Admin?section=messages&filter=all" class="filter-tab @(filterParam != "unread" && filterParam != "read" ? "active" : "")">All</a>
                                <a href="/Admin?section=messages&filter=unread" class="filter-tab @(filterParam == "unread" ? "active" : "")">Unread <span class="nav-badge">@cntUnreadMsgs</span></a>
                                <a href="/Admin?section=messages&filter=read" class="filter-tab @(filterParam == "read" ? "active" : "")">Read</a>
                            </div>
                            <form method="post" action="/Admin?section=messages" style="display:inline">
                                <input name="action" value="mark_all_read" type="hidden">
                                <button type="submit" class="btn btn-sm" style="background:#00b894;color:#fff" id="mark-all-read-btn">
                                    <i class="fa-solid fa-check-double"></i> Mark All Read
                                </button>
                            </form>
                        </div>

                        <div class="table-wrap">
                            <table class="admin-table">
                                <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Subject</th><th>Message</th><th>Received</th><th>Status</th><th>Actions</th></tr></thead>
                                <tbody>
                                @{ int mIdx = 1; }
                                @foreach (dynamic m in messages)
                                {
                                    var msgPreview = m.Message.Length > 60 ? m.Message.Substring(0, 60) + "…" : m.Message;
                                    <tr class="@(!m.IsRead ? "unread-row" : "")">
                                        <td>@(mIdx++)</td>
                                        <td><strong>@m.Name</strong></td>
                                        <td><a href="mailto:@m.Email" class="email-link">@m.Email</a></td>
                                        <td>@m.Subject</td>
                                        <td><span title="@m.Message" class="msg-preview">@msgPreview</span></td>
                                        <td>@m.ReceivedAt</td>
                                        <td>
                                            @if ((bool)m.IsRead)
                                            { <span class="badge badge-secondary">Read</span> }
                                            else
                                            { <span class="badge badge-danger" style="font-weight:700">Unread</span> }
                                        </td>
                                        <td class="action-cell">
                                            <form method="post" action="/Admin?section=messages" style="display:inline">
                                                <input name="action" value="toggle_msg" type="hidden">
                                                <input name="msg_id" value="@m.Id" type="hidden">
                                                <button type="submit" class="btn btn-sm" style="background:#636e72;color:#fff" title="Toggle read/unread"><i class="fa-solid fa-envelope-open"></i></button>
                                            </form>
                                            <form method="post" action="/Admin?section=messages" style="display:inline">
                                                <input name="action" value="delete_msg" type="hidden">
                                                <input name="msg_id" value="@m.Id" type="hidden">
                                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this message?')"><i class="fa-solid fa-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                                @if (!messages.Any())
                                {
                                    <tr><td colspan="8" class="empty-row">No messages found.</td></tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ══════════════ SECTION: VOLUNTEERS ══════════════ -->
            <section id="sec-volunteers" style="display:@Show("volunteers")">
                <div class="section-body">
                    <div class="card-box">
                        <div class="section-toolbar">
                            <div class="filter-tabs">
                                <a href="/Admin?section=volunteers&filter=all" class="filter-tab @(filterParam != "Pending" && filterParam != "Approved" && filterParam != "Rejected" ? "active" : "")">All</a>
                                <a href="/Admin?section=volunteers&filter=Pending" class="filter-tab @(filterParam == "Pending" ? "active" : "")">🟡 Pending <span class="nav-badge">@cntPendingVols</span></a>
                                <a href="/Admin?section=volunteers&filter=Approved" class="filter-tab @(filterParam == "Approved" ? "active" : "")">🟢 Approved</a>
                                <a href="/Admin?section=volunteers&filter=Rejected" class="filter-tab @(filterParam == "Rejected" ? "active" : "")">🔴 Rejected</a>
                            </div>
                        </div>

                        <div class="table-wrap">
                            <table class="admin-table">
                                <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Phone</th><th>Submitted</th><th>Status</th><th>Actions</th></tr></thead>
                                <tbody>
                                @{ int vIdx = 1; }
                                @foreach (dynamic v in volunteers)
                                {
                                    var vBadge = v.Status == "Approved" ? "badge-success" : v.Status == "Rejected" ? "badge-danger" : "badge-warning";
                                    <tr>
                                        <td>@(vIdx++)</td>
                                        <td><strong>@v.Name</strong></td>
                                        <td><a href="mailto:@v.Email" class="email-link">@v.Email</a></td>
                                        <td>@v.Phone</td>
                                        <td>@v.SubmittedAt</td>
                                        <td><span class="badge @vBadge">@v.Status</span></td>
                                        <td class="action-cell">
                                            @if (v.Status != "Approved")
                                            {
                                                <form method="post" action="/Admin?section=volunteers" style="display:inline">
                                                    <input name="action" value="set_volunteer_status" type="hidden">
                                                    <input name="vol_id" value="@v.Id" type="hidden">
                                                    <input name="vol_status" value="Approved" type="hidden">
                                                    <button type="submit" class="btn btn-success btn-sm"><i class="fa-solid fa-check"></i> Approve</button>
                                                </form>
                                            }
                                            @if (v.Status != "Rejected")
                                            {
                                                <form method="post" action="/Admin?section=volunteers" style="display:inline">
                                                    <input name="action" value="set_volunteer_status" type="hidden">
                                                    <input name="vol_id" value="@v.Id" type="hidden">
                                                    <input name="vol_status" value="Rejected" type="hidden">
                                                    <button type="submit" class="btn btn-danger btn-sm"><i class="fa-solid fa-xmark"></i> Reject</button>
                                                </form>
                                            }
                                            <form method="post" action="/Admin?section=volunteers" style="display:inline">
                                                <input name="action" value="delete_volunteer" type="hidden">
                                                <input name="vol_id" value="@v.Id" type="hidden">
                                                <button type="submit" class="btn btn-sm" style="background:#636e72;color:#fff" onclick="return confirm('Delete this volunteer record?')"><i class="fa-solid fa-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                                @if (!volunteers.Any())
                                {
                                    <tr><td colspan="7" class="empty-row">No volunteers found.</td></tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ══════════════ SECTION: SITE STATS ══════════════ -->
            <section id="sec-stats" style="display:@Show("stats")">
                <div class="section-body">
                    <div class="card-box" style="max-width:520px">
                        <h3 class="section-title"><i class="fa-solid fa-chart-bar"></i> Update Site Statistics</h3>
                        <p style="color:var(--muted);font-size:.85rem;margin:0 0 20px">These numbers appear on the public homepage as key impact metrics.</p>
                        <form method="post" action="/Admin?section=stats">
                            <input name="action" value="save_stats" type="hidden">
                            <div class="stats-form-grid">
                                <div class="stat-input-card">
                                    <div class="stat-input-icon" style="background:#fde8ec"><i class="fa-solid fa-people-group" style="color:#e94560"></i></div>
                                    <div class="form-group" style="margin:0">
                                        <label for="stat_volunteers">Volunteers Count</label>
                                        <input type="number" id="stat_volunteers" name="stat_volunteers" value="@statVolunteers" min="0" required>
                                    </div>
                                </div>
                                <div class="stat-input-card">
                                    <div class="stat-input-icon" style="background:#dbeeff"><i class="fa-solid fa-diagram-project" style="color:#0984e3"></i></div>
                                    <div class="form-group" style="margin:0">
                                        <label for="stat_projects">Projects Count</label>
                                        <input type="number" id="stat_projects" name="stat_projects" value="@statProjects" min="0" required>
                                    </div>
                                </div>
                                <div class="stat-input-card">
                                    <div class="stat-input-icon" style="background:#d4f7ee"><i class="fa-solid fa-heart-pulse" style="color:#00b894"></i></div>
                                    <div class="form-group" style="margin:0">
                                        <label for="stat_helped">People Helped</label>
                                        <input type="number" id="stat_helped" name="stat_helped" value="@statHelped" min="0" required>
                                    </div>
                                </div>
                                <div class="stat-input-card">
                                    <div class="stat-input-icon" style="background:#ede9fd"><i class="fa-solid fa-calendar-days" style="color:#6c5ce7"></i></div>
                                    <div class="form-group" style="margin:0">
                                        <label for="stat_years">Years Active</label>
                                        <input type="number" id="stat_years" name="stat_years" value="@statYears" min="0" required>
                                    </div>
                                </div>
                            </div>
                            <div class="form-actions" style="margin-top:24px">
                                <button type="submit" class="btn btn-primary" id="save-stats-btn">
                                    <i class="fa-solid fa-floppy-disk"></i> Update Statistics
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </section>

        </main>
    </div>
}

<script>
    // Auto-hide flash message after 4 seconds
    const flash = document.getElementById('flash-msg');
    if (flash) setTimeout(() => { flash.style.opacity = '0'; flash.style.transition = 'opacity .5s'; setTimeout(() => flash.remove(), 500); }, 4000);
</script>

</body>
</html>
